---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { projects, getProjectBySlug } from "@/data/projects";
import { projectGalleries } from "@/data/projectGalleries";

export function getStaticPaths() {
  return projects
    .filter((project) => !project.legacyPath.startsWith("http"))
    .map((project) => ({ params: { slug: project.slug } }));
}

const project = getProjectBySlug(Astro.params.slug ?? "");

if (!project) {
  return Astro.redirect("/404/");
}

const coverSrc = project.heroImage ?? `/images/projects/${project.slug}/cover.webp`;
const galleryImages = projectGalleries[project.slug] ?? [];

const backHref = project.category === "archive" ? "/archive/" : "/";
const projectKind =
  project.category === "game"
    ? "Game Project"
    : project.category === "experience"
      ? "Experience Project"
      : "Archive Project";
const visualSections = project.visualSections ?? [];
const caseStudySections = project.caseStudySections ?? [];
const getVideoEmbedUrl = (url: string, type?: string) => {
  if (type === "vimeo" || url.includes("vimeo.com")) {
    const id = url.match(/vimeo\.com\/(\d+)/)?.[1];
    return id ? `https://player.vimeo.com/video/${id}` : url;
  }

  const id =
    url.match(/youtu\.be\/([^?&/]+)/)?.[1] ??
    url.match(/[?&]v=([^?&/]+)/)?.[1] ??
    url.match(/youtube\.com\/embed\/([^?&/]+)/)?.[1];

  return id ? `https://www.youtube.com/embed/${id}` : url;
};
const anchorLinks = [
  ...(project.impacts?.length ? [{ href: "#impact", label: "Impact" }] : []),
  ...visualSections.map((section) => ({
    href: `#${section.id}`,
    label: section.label
  })),
  ...caseStudySections.map((section) => ({
    href: `#${section.id}`,
    label: section.label
  })),
  ...(!caseStudySections.length && !visualSections.length ? (project.sections ?? []).map((section) => ({
    href: `#${section.title.toLowerCase().replaceAll(" ", "-").replaceAll("/", "-")}`,
    label: section.title
  })) : []),
  ...(galleryImages.length && !caseStudySections.length && !visualSections.length ? [{ href: "#gallery", label: "Gallery" }] : [])
];
---

<BaseLayout
  title={project.title}
  description={project.summary}
  path={`/projects/${project.slug}/`}
>
  <article class="project-detail">
    <a class="back-link" href={backHref}>Back</a>
    {anchorLinks.length > 0 && (
      <nav class="project-jump-nav" aria-label={`${project.title} page sections`}>
        {anchorLinks.map((link) => <a href={link.href}>{link.label}</a>)}
      </nav>
    )}
    <div class:list={["detail-hero", caseStudySections.length && "case-study-hero", visualSections.length && "visual-project-hero"]}>
      <div>
        <p class="eyebrow">{projectKind}</p>
        <h1>{project.title}</h1>
        {project.subtitle && <p class="project-subtitle">{project.subtitle}</p>}
        {project.summary && <p>{project.summary}</p>}
        <div class="detail-actions">
          {project.externalLinks?.map((link) => (
            <a class="button primary" href={link.href}>{link.label}</a>
          ))}
        </div>
      </div>
      <div class="project-media large">
        <img src={coverSrc} alt="" />
        {!caseStudySections.length && !visualSections.length && <span>{project.title}</span>}
      </div>
    </div>
    {visualSections.length > 0 && (
      <section class="visual-project-meta" aria-label={`${project.title} project details`}>
        {project.deliverables && (
          <div>
            <strong>Deliverables</strong>
            <span>{project.deliverables}</span>
          </div>
        )}
        {project.timeSpan && (
          <div>
            <strong>Time Span</strong>
            <span>{project.timeSpan}</span>
          </div>
        )}
        {project.team && (
          <div>
            <strong>Team</strong>
            <span>{project.team.join(", ")}</span>
          </div>
        )}
        {!project.deliverables && <span>{project.role}</span>}
        {!project.timeSpan && project.subtitle && <span>{project.subtitle}</span>}
      </section>
    )}
    {!visualSections.length && (
    <section class="detail-body detail-overview">
      <div>
        <h2>Project Overview</h2>
        {(project.description ?? [project.summary]).map((paragraph) => <p>{paragraph}</p>)}
      </div>
      <dl class="project-facts">
        {project.deliverables && (
          <div>
            <dt>Deliverables</dt>
            <dd>{project.deliverables}</dd>
          </div>
        )}
        {project.timeSpan && (
          <div>
            <dt>Time Span</dt>
            <dd>{project.timeSpan}</dd>
          </div>
        )}
        {project.team && (
          <div>
            <dt>Team</dt>
            <dd>{project.team.join(", ")}</dd>
          </div>
        )}
        <div>
          <dt>Role / Tags</dt>
          <dd>{project.role}</dd>
        </div>
        <div>
          <dt>Original Route</dt>
          <dd>{project.legacyPath}</dd>
        </div>
      </dl>
    </section>
    )}
    {project.impacts && (
      <section class="impact-section" id="impact">
        <p class="eyebrow">My Impact</p>
        <h2>My Impact</h2>
        <div class="impact-grid">
          {project.impacts.map((impact, index) => (
            <article>
              <span>{String(index + 1).padStart(2, "0")}</span>
              <p>{impact}</p>
            </article>
          ))}
        </div>
      </section>
    )}
    {visualSections.map((section) => (
      <section
        class:list={[
          "visual-story-section",
          section.variant && `visual-story-${section.variant}`,
          section.media.length === 0 && "visual-story-text-only"
        ]}
        id={section.id}
      >
        <div class="visual-story-copy">
          <p class="eyebrow">{section.label}</p>
          <h2>{section.title}</h2>
          {section.body && <p>{section.body}</p>}
          {section.points && (
            <div class="visual-story-points">
              {section.points.map((point) => (
                <article>
                  <h3>{point.title}</h3>
                  <p>{point.body}</p>
                </article>
              ))}
            </div>
          )}
        </div>
        {section.media.length > 0 && (
          <div class="visual-story-media">
            {section.media.map((item) => (
              <figure class:list={[item.span && `visual-${item.span}`]}>
                {item.type === "youtube" || item.type === "vimeo" ? (
                  <div class="video-embed">
                    <iframe
                      src={getVideoEmbedUrl(item.src, item.type)}
                      title={item.alt}
                      loading="lazy"
                      allow="accelerometer; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                      allowfullscreen
                    ></iframe>
                  </div>
                ) : (
                  <a class="image-open-link" href={item.src} target="_blank" rel="noreferrer" aria-label={`Open image: ${item.alt}`}>
                    <img src={item.src} alt={item.alt} loading="lazy" />
                  </a>
                )}
                {item.caption && <figcaption>{item.caption}</figcaption>}
              </figure>
            ))}
          </div>
        )}
      </section>
    ))}
    {!visualSections.length && caseStudySections.map((section) => (
      <section
        class:list={[
          "case-study-section",
          `case-study-${section.media?.length ? section.variant ?? "split" : "text"}`
        ]}
        id={section.id}
      >
        <div class="case-study-copy">
          {section.eyebrow && <p class="eyebrow">{section.eyebrow}</p>}
          <h2>{section.title}</h2>
          {section.body.map((paragraph) => <p>{paragraph}</p>)}
          {section.callout && <p class="case-study-callout">{section.callout}</p>}
        </div>
        {section.media && (
          <div class="case-study-media">
            {section.media.map((item) => (
              <figure>
                <img src={item.src} alt={item.alt} loading="lazy" />
                <figcaption>{item.caption}</figcaption>
              </figure>
            ))}
          </div>
        )}
      </section>
    ))}
    {!visualSections.length && !caseStudySections.length && project.sections?.map((section) => (
      <section class="narrative-section" id={section.title.toLowerCase().replaceAll(" ", "-").replaceAll("/", "-")}>
        <h2>{section.title}</h2>
        {section.body.map((paragraph) => <p>{paragraph}</p>)}
      </section>
    ))}
    {galleryImages.length > 0 && !caseStudySections.length && !visualSections.length && (
      <section class="detail-gallery" id="gallery" aria-label={`${project.title} image gallery`}>
        {galleryImages.map((image, index) => (
          <figure>
            <img src={image} alt={`${project.title} gallery image ${index + 1}`} loading="lazy" />
          </figure>
        ))}
      </section>
    )}
  </article>
</BaseLayout>
