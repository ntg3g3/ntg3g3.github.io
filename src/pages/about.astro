---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { site } from "@/data/site";
---

<BaseLayout
  title="About"
  description="About Yutao Huang, a game designer and experience designer."
  path="/about/"
>
  <section class="page-intro about-intro">
    <p class="eyebrow">About</p>
    <h1>Yutao Huang designs gameplay, progression, and interactive systems.</h1>
    <p>
      I am a gameplay and systems designer focused on player growth, mechanics,
      progression frameworks, UX flow, and clear implementation-ready design.
      My background also includes research prototypes, immersive experiences,
      educational play, and physical-digital interaction.
    </p>
  </section>

  <section class="about-grid">
    <article>
      <h2>Focus</h2>
      <p>
        Systems design, progression design, gameplay mechanics, mission/task frameworks,
        live-ops feature design, UX flow, and level/tutorial structures.
      </p>
    </article>
    <article>
      <h2>Background</h2>
      <p>
        After graduating from the Entertainment Technology Center at Carnegie Mellon University,
        I worked on Skyweaver, a web3 trading card game, then continued into mobile systems
        design work involving progression, task, economy, event, and onboarding frameworks.
      </p>
    </article>
    <article>
      <h2>Selected Skills</h2>
      <p>
        Systems design, progression design, mechanic design, UX flow design, Unity, Figma,
        Excel / Google Sheets, Git / Perforce workflows, and cross-discipline collaboration.
      </p>
    </article>
    <article>
      <h2>Contact</h2>
      <p><a href={`mailto:${site.email}`}>{site.email}</a></p>
      <p>{site.phone}</p>
    </article>
  </section>
</BaseLayout>
