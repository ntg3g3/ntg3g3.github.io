---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { site } from "@/data/site";
---

<BaseLayout
  title="About"
  description="About Yutao Huang, a game designer and experience designer."
  path="/about/"
>
  <section class="page-intro about-intro">
    <p class="eyebrow">About</p>
    <h1>Yutao Huang designs games, experiences, and interactive systems.</h1>
    <p>
      I am a game designer focused on playful systems, immersive experiences, and design
      prototypes that help people learn, collaborate, and see familiar interactions in new ways.
      My work spans strategy games, location-based entertainment, VR/AR, body tracking,
      educational play, and physical-digital product concepts.
    </p>
  </section>

  <section class="about-grid">
    <article>
      <h2>Focus</h2>
      <p>
        Game design, experience design, level design, educational play, immersive media,
        and interactive research prototypes. I enjoy building systems with clear rules,
        expressive player choices, and moments that feel natural in the body.
      </p>
    </article>
    <article>
      <h2>Background</h2>
      <p>
        After graduating from the Entertainment Technology Center at Carnegie Mellon University,
        I worked on Skyweaver, a web3 trading card game, and contributed to design, QA,
        documentation, event systems, and player-facing improvements.
      </p>
    </article>
    <article>
      <h2>Selected Skills</h2>
      <p>
        Systems design, level design, prototyping, research-driven design, Unity, VR/AR,
        body tracking, UX thinking, product design, and cross-discipline collaboration.
      </p>
    </article>
    <article>
      <h2>Contact</h2>
      <p><a href={`mailto:${site.email}`}>{site.email}</a></p>
      <p>{site.phone}</p>
      <p class="muted-note">Contact details can be adjusted before launch if you prefer a less public version.</p>
    </article>
  </section>
</BaseLayout>
